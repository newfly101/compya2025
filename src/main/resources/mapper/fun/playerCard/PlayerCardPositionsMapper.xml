<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dawne.com2usbaseball.domain.fun.playerCard.mapper.PlayerCardPositionsMapper">

    <resultMap id="PlayerCardPositionsResultMap"
               type="com.dawne.com2usbaseball.domain.fun.playerCard.entity.PlayerCardPositionsEntity">
        <id property="id" column="id"/>
        <result property="cardId" column="card_id"/>
        <result property="positionCode" column="position_code"/>
        <result property="displayOrder" column="display_order"/>
    </resultMap>

    <insert id="insert"
            parameterType="com.dawne.com2usbaseball.domain.fun.playerCard.entity.PlayerCardPositionsEntity"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO fun_player_card_positions
        (
            card_id,
            position_code,
            display_order
        )
        VALUES
            (
                #{cardId},
                #{positionCode},
                #{displayOrder}
            )
    </insert>

    <update id="update"
            parameterType="com.dawne.com2usbaseball.domain.fun.playerCard.entity.PlayerCardPositionsEntity">
        UPDATE fun_player_card_positions
        SET
            card_id = #{cardId},
            position_code = #{positionCode},
            display_order = #{displayOrder}
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="long">
        DELETE FROM fun_player_card_positions
        WHERE id = #{id}
    </delete>

    <delete id="deleteByCardId" parameterType="long">
        DELETE FROM fun_player_card_positions
        WHERE card_id = #{cardId}
    </delete>

    <select id="findById" parameterType="long" resultMap="PlayerCardPositionsResultMap">
        SELECT
            id,
            card_id,
            position_code,
            display_order
        FROM fun_player_card_positions
        WHERE id = #{id}
    </select>

    <select id="findByCardId" parameterType="long" resultMap="PlayerCardPositionsResultMap">
        SELECT
            id,
            card_id,
            position_code,
            display_order
        FROM fun_player_card_positions
        WHERE card_id = #{cardId}
        ORDER BY display_order ASC, id ASC
    </select>

    <select id="findAll" resultMap="PlayerCardPositionsResultMap">
        SELECT
            id,
            card_id,
            position_code,
            display_order
        FROM fun_player_card_positions
        ORDER BY card_id ASC, display_order ASC, id ASC
    </select>

</mapper>
